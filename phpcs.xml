<?xml version="1.0"?>
<ruleset name="Newspack Monorepo Coding Standards">
	<description>Shared PHPCS configuration for all Newspack plugins and themes.</description>

	<arg value="sp"/>
	<arg name="colors"/>
	<arg name="extensions" value="php"/>
	<arg name="parallel" value="8"/>

	<!-- Rule set based on WordPress-VIP-Go and WordPress-Extra. Individual
	     plugins can override via their own phpcs.xml if needed. -->
	<rule ref="WordPress-VIP-Go"/>
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<config name="minimum_wp_version" value="6.6"/>
	<config name="testVersion" value="8.0-"/>

	<!-- Scan only in-scope monorepo code. -->
	<file>plugins</file>
	<file>themes</file>
	<file>packages</file>

	<!-- Exclude build output, deps, tests fixtures, and workspace scaffolding. -->
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>*/tests/fixtures/*</exclude-pattern>
	<exclude-pattern>*/release/*</exclude-pattern>
</ruleset>
